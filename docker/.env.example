# LiteLLM master key — используется как Bearer token в API-запросах
# Должен начинаться с "sk-"
# Сгенерировать: echo "sk-$(openssl rand -hex 32)"
LITELLM_MASTER_KEY=sk-your-master-key

# Учётные данные для входа в LiteLLM UI (http://localhost:4000/ui)
UI_USERNAME=ui-username
UI_PASSWORD=ui-password

# Пароль для PostgreSQL (используется внутри сети, наружу не проброшен)
# Сгенерировать: openssl rand -hex 16
POSTGRES_PASSWORD=your-postgres-password